<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Climate EWS Zambia</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="../templatemo-glass-admin-style.css">
    <style>
        :root {
            --climate-green: #10b981;
            --climate-green-dark: #059669;
            --risk-low: #22c55e;
            --risk-medium: #34d399;
            --risk-high: #f97316;
            --risk-critical: #dc2626;
        }
        
        .logo-text-climate {
            background: linear-gradient(135deg, var(--climate-green), var(--climate-white)) !important;
            -webkit-background-clip: text !important;
            -webkit-text-fill-color: transparent !important;
            background-clip: text !important;
        }
        
        .risk-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
        }
        
        .risk-badge.low { background: rgba(34, 197, 94, 0.2); color: var(--risk-low); }
        .risk-badge.medium { background: rgba(234, 179, 8, 0.2); color: var(--risk-medium); }
        .risk-badge.high { background: rgba(249, 115, 22, 0.2); color: var(--risk-high); }
        .risk-badge.critical { background: rgba(220, 38, 38, 0.2); color: var(--risk-critical); }
        
        .stat-card.admin::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--climate-green), var(--climate-green-dark));
        }
    </style>
</head>
<body>
    <div class="background"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="dashboard">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="logo" style="background: linear-gradient(135deg, var(--climate-green), var(--climate-green-dark));">🌦️</div>
                <span class="logo-text logo-text-climate">Admin Panel</span>
            </div>

            <ul class="nav-menu">
                <li class="nav-section">
                    <span class="nav-section-title">Administration</span>
                    <ul>
                        <li class="nav-item">
                            <a href="dashboard.html" class="nav-link active">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="3" width="7" height="7" rx="1"/>
                                    <rect x="14" y="3" width="7" height="7" rx="1"/>
                                    <rect x="3" y="14" width="7" height="7" rx="1"/>
                                    <rect x="14" y="14" width="7" height="7" rx="1"/>
                                </svg>
                                Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="users.html" class="nav-link">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                    <circle cx="9" cy="7" r="4"/>
                                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                </svg>
                                Users
                            </a>
                        </li>
                    </ul>
                </li>

                <li class="nav-section">
                    <span class="nav-section-title">Public Site</span>
                    <ul>
                        <li class="nav-item">
                            <a href="../index.html" class="nav-link" target="_blank">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                                    <polyline points="15 3 21 3 21 9"/>
                                    <line x1="10" y1="14" x2="21" y2="3"/>
                                </svg>
                                Public Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="../index.html" class="nav-link" target="_blank">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                                    <polyline points="16 17 21 12 16 7"/>
                                    <line x1="21" y1="12" x2="9" y2="12"/>
                                </svg>
                                Logout
                            </a>
                        </li>
                    </ul>
                </li>
            </ul>

            <div class="sidebar-footer">
                <div class="user-profile">
                    <div class="user-avatar" style="background: linear-gradient(135deg, var(--climate-green), var(--climate-green-dark));" id="admin-avatar">AD</div>
                    <div class="user-info">
                        <div class="user-name" id="admin-name">Administrator</div>
                        <div class="user-role">System Admin</div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Top Navbar -->
            <nav class="navbar">
                <h1 class="page-title">Admin Dashboard</h1>
                <div class="navbar-right">
                    <button class="nav-btn" id="refresh-data" title="Refresh Data">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="23 4 23 10 17 10"/>
                            <polyline points="1 20 1 14 7 14"/>
                            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
                        </svg>
                    </button>
                </div>
            </nav>

            <!-- Stats Cards -->
            <section class="stats-grid">
                <div class="glass-card glass-card-3d stat-card admin">
                    <div class="stat-card-inner">
                        <div class="stat-info">
                            <h3>Total Alerts</h3>
                            <div class="stat-value" id="total-alerts">--</div>
                            <span class="stat-change" id="alerts-trend">Loading...</span>
                        </div>
                        <div class="weather-icon-container" style="background: linear-gradient(135deg, rgba(255, 215, 0, 0.2), rgba(184, 134, 11, 0.2));">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2">
                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                                <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="glass-card glass-card-3d stat-card admin">
                    <div class="stat-card-inner">
                        <div class="stat-info">
                            <h3>Critical/High Risk</h3>
                            <div class="stat-value" id="critical-alerts">--</div>
                            <span class="stat-change" style="color: var(--risk-high);">Active Threats</span>
                        </div>
                        <div class="weather-icon-container" style="background: linear-gradient(135deg, rgba(220, 38, 38, 0.2), rgba(249, 115, 22, 0.2));">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2">
                                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                                <line x1="12" y1="9" x2="12" y2="13"/>
                                <line x1="12" y1="17" x2="12.01" y2="17"/>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="glass-card glass-card-3d stat-card admin">
                    <div class="stat-card-inner">
                        <div class="stat-info">
                            <h3>Subscribed Users</h3>
                            <div class="stat-value" id="total-users">--</div>
                            <span class="stat-change" id="users-trend">Loading...</span>
                        </div>
                        <div class="weather-icon-container" style="background: linear-gradient(135deg, rgba(5, 150, 105, 0.2), rgba(34, 197, 94, 0.2));">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                <circle cx="9" cy="7" r="4"/>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="glass-card glass-card-3d stat-card admin">
                    <div class="stat-card-inner">
                        <div class="stat-info">
                            <h3>Manual Alerts</h3>
                            <div class="stat-value" id="manual-alerts">--</div>
                            <span class="stat-change">Admin Generated</span>
                        </div>
                        <div class="weather-icon-container" style="background: linear-gradient(135deg, rgba(37, 99, 235, 0.2), rgba(59, 130, 246, 0.2));">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Content Grid -->
            <section class="content-grid">
                <!-- Manual Alert Form -->
                <div class="glass-card">
                    <div class="card-header">
                        <div>
                            <h2 class="card-title">Trigger Manual Alert</h2>
                            <p class="card-subtitle">Send emergency notification to all users</p>
                        </div>
                    </div>
                    <form id="manual-alert-form">
                        <div style="display: grid; gap: 16px;">
                            <div>
                                <label style="display: block; margin-bottom: 8px; font-size: 13px; color: var(--text-secondary);">Risk Level *</label>
                                <select class="form-input" id="alert-risk-level" required style="width: 100%; padding: 12px; background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 10px; color: var(--text-primary);">
                                    <option value="low">Low</option>
                                    <option value="medium">Medium</option>
                                    <option value="high">High</option>
                                    <option value="critical">Critical</option>
                                </select>
                            </div>
                            <div>
                                <label style="display: block; margin-bottom: 8px; font-size: 13px; color: var(--text-secondary);">Disaster Type *</label>
                                <select class="form-input" id="alert-disaster-type" required style="width: 100%; padding: 12px; background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 10px; color: var(--text-primary);">
                                    <option value="flood">Flood</option>
                                    <option value="drought">Drought</option>
                                    <option value="extreme_temperature">Extreme Temperature</option>
                                    <option value="storm">Storm</option>
                                    <option value="general">General Warning</option>
                                </select>
                            </div>
                            <div>
                                <label style="display: block; margin-bottom: 8px; font-size: 13px; color: var(--text-secondary);">Region (Optional)</label>
                                <select class="form-input" id="alert-region" style="width: 100%; padding: 12px; background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 10px; color: var(--text-primary);">
                                    <option value="">National (All Regions)</option>
                                    <option value="1">Lusaka</option>
                                    <option value="2">Copperbelt</option>
                                    <option value="3">Eastern</option>
                                    <option value="4">Northern</option>
                                    <option value="5">Southern</option>
                                    <option value="6">Central</option>
                                    <option value="7">North-Western</option>
                                    <option value="8">Luapula</option>
                                    <option value="9">Muchinga</option>
                                    <option value="10">Western</option>
                                </select>
                            </div>
                            <div>
                                <label style="display: block; margin-bottom: 8px; font-size: 13px; color: var(--text-secondary);">Alert Message *</label>
                                <textarea class="form-input" id="alert-message" rows="4" required placeholder="Enter alert message..." style="width: 100%; padding: 12px; background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 10px; color: var(--text-primary); resize: vertical;"></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 14px; background: linear-gradient(135deg, var(--climate-green), var(--climate-green-dark)); border: none; border-radius: 10px; color: white; font-weight: 600; cursor: pointer;">
                                Send Alert to All Users
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Recent Alerts Table -->
                <div class="glass-card table-card">
                    <div class="card-header">
                        <div>
                            <h2 class="card-title">Recent Alerts</h2>
                            <p class="card-subtitle">Latest generated alerts</p>
                        </div>
                        <div class="card-actions">
                            <button class="card-btn" onclick="loadAlerts()">Refresh</button>
                        </div>
                    </div>
                    <div class="table-wrapper">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Risk Level</th>
                                    <th>Message</th>
                                    <th>Region</th>
                                    <th>Type</th>
                                    <th>Date</th>
                                    <th>Sent</th>
                                </tr>
                            </thead>
                            <tbody id="alerts-table-body">
                                <tr>
                                    <td colspan="6" style="text-align: center; padding: 40px; color: var(--text-muted);">
                                        Loading alerts...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <!-- Mobile Menu Toggle -->
    <button class="mobile-menu-toggle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>

    <!-- Footer -->
    <footer class="site-footer">
        <p>Copyright © 2026 Climate EWS Zambia | Admin Panel</p>
    </footer>

    <script src="../templatemo-glass-admin-script.js"></script>
    <script src="admin-dashboard.js"></script>
</body>
</html>
