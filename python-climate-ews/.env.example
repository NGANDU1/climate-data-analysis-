# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-this-in-production
DATABASE_URL=sqlite:///climate_ews.db

# Open-data auto sync (NASA POWER)
AUTO_SYNC_ENABLED=true
AUTO_SYNC_INTERVAL_HOURS=24
AUTO_SYNC_LOOKBACK_DAYS=3

# Production Settings (uncomment for production)
# FLASK_ENV=production
# SECRET_KEY=super-secret-production-key-change-this
# DATABASE_URL=postgresql://user:password@localhost/dbname

# Optional: External Services (for production)
# SMS_SERVICE_API_KEY=your-twilio-api-key
# EMAIL_SERVICE_API_KEY=your-sendgrid-api-key
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587

# Earthdata (for satellite datasets like GPM IMERG)
# Create a token or use username/password, and ensure your account is authorized for GES DISC.
# EARTHDATA_TOKEN=your_earthdata_token_here
# EARTHDATA_USERNAME=your_earthdata_username
# EARTHDATA_PASSWORD=your_earthdata_password
