# Core config
SECRET_KEY=change_me
DATABASE_URL=sqlite:///instance/climate_ews.db
OPENWEATHER_API_KEY=paste_your_key_here

# Automatic notifications
# If NOTIFICATIONS_SIMULATE=true, the system prints messages to the server console when SMTP/Twilio aren't configured.
NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_SIMULATE=true
NOTIFICATIONS_POLL_SECONDS=60
NOTIFICATIONS_MAX_ALERTS_PER_RUN=25
NOTIFICATIONS_LOOKBACK_HOURS=168

# Email via SMTP (optional, required for real email delivery when NOTIFICATIONS_SIMULATE=false)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Climate EWS <your_email@gmail.com>"

# SMS via Twilio (optional, required for real SMS delivery when NOTIFICATIONS_SIMULATE=false)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+1234567890

# Social sign-in (OAuth)
# GitHub OAuth app callback URL:
#   http://localhost:5000/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth redirect URI:
#   http://localhost:5000/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
